<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #0F0F0F;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mitodolist.LoginController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>

    <Label fx:id="lblTitulo" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Seguridad" />
    
    <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 14px;" text="Por favor, introduce tus credenciales para continuar." />

    <TextField fx:id="txtNombre" maxWidth="250.0" prefHeight="40.0" promptText="Tu Nombre de Usuario" style="-fx-background-color: #1E1E1E; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-font-size: 16px;" />

    <PasswordField fx:id="txtPin" maxWidth="250.0" prefHeight="40.0" promptText="PIN Secreto" style="-fx-background-color: #1E1E1E; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-font-size: 16px;" />

    <CheckBox fx:id="chkRecordar" style="-fx-text-fill: white; -fx-font-size: 14px;" text="Mantener mi sesión iniciada" />

    <Button fx:id="btnAcceder" maxWidth="250.0" onAction="#accionAcceder" prefHeight="45.0" style="-fx-background-color: #C2185B; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="Acceder" />

    <!-- Botón tipo hipervínculo para cambiar entre Login y Registro -->
    <Button fx:id="btnCambiarModo" onAction="#alternarModo" style="-fx-background-color: transparent; -fx-text-fill: #2196F3; -fx-cursor: hand; -fx-underline: true;" text="¿No tienes cuenta? Regístrate" />

</VBox>